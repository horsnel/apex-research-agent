# APEX Research Agent — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Database ──
DATABASE_URL=postgresql://apex:apex_secret@localhost:5432/apex_db

# ── Cloudflare Workers AI (9-model fallback chain — primary provider) ──
CLOUDFLARE_API_TOKEN=cfut_your-token-here
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1

# ── GitHub Models (fallback provider — free tier) ──
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com

# ── OpenAI / Embeddings ──
OPENAI_API_KEY=sk-your-openai-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Legacy LLM (kept as final fallback) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Live Scraper (Firecrawl) ──
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# ── Reranking ──
COHERE_API_KEY=co-your-key-here

# ── MCP Server ──
MCP_HOST=0.0.0.0
MCP_PORT=8081

# ── FastAPI ──
API_HOST=0.0.0.0
API_PORT=8000

# ── Token Limits ──
MAX_RAG_CONTEXT_TOKENS=2000
MAX_LIVE_SCRAPE_TOKENS=3000
MAX_SYNTHESIS_TOKENS=300
DEFAULT_SYNTHESIS_TOKENS=150

# ── Retrieval ──
RAG_TOP_K=5
RAG_FINAL_K=3
SIMILARITY_THRESHOLD=0.72
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_PCT=0.20
