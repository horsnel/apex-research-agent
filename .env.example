# ═══════════════════════════════════════════════════════════════
# APEX Research Agent — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All variables are optional unless marked REQUIRED.
# ═══════════════════════════════════════════════════════════════

# ── Cloudflare Workers AI (Primary LLM Provider) ──
# REQUIRED: API token from https://dash.cloudflare.com/profile/api-tokens
# Must have "Workers AI" permission enabled
CLOUDFLARE_API_TOKEN=cfut_your_token_here

# Auto-detected from token if left empty. Set manually to skip detection.
CLOUDFLARE_ACCOUNT_ID=

# ── GitHub Models (Free Tier Fallback, 150 req/day) ──
# Optional: Personal access token from https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# ── OpenAI (Embeddings) ──
# REQUIRED for RAG: For text-embedding-3-small embeddings
OPENAI_API_KEY=sk-your_key_here

# ── Anthropic (Legacy Fallback) ──
# Optional: Direct Anthropic API access
ANTHROPIC_API_KEY=

# ── Cohere (Reranking) ──
# Optional: For search result reranking
# If not set, CF Workers AI Granite-4.0-Micro is used as free reranker
COHERE_API_KEY=

# ── Web Scraping ──
# Three-tier scraper: httpx+BS4 (free) → Jina Reader → Firecrawl

# Jina Reader: Free API key from https://jina.ai/
# Better quality than raw HTTP, handles JS rendering
JINA_API_KEY=

# Firecrawl: Premium scraper from https://firecrawl.dev/
# 500 free credits/month, best quality
FIRECRAWL_API_KEY=

# Note: If no scraper keys are set, the system uses:
# - DuckDuckGo Lite for web search (free, no key)
# - httpx + BeautifulSoup for scraping (free, no key)
# This is enough for basic functionality.

# ── Database ──
# PostgreSQL + pgvector. Run: docker-compose up -d db
DATABASE_URL=postgresql://apex:apex_secret@localhost:5432/apex_db

# ── Embedding Model ──
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Synthesis Token Budget ──
DEFAULT_SYNTHESIS_TOKENS=150
MAX_SYNTHESIS_TOKENS=300

# ── RAG Configuration ──
RAG_TOP_K=5
RAG_FINAL_K=3
MAX_RAG_CONTEXT_TOKENS=2000
SIMILARITY_THRESHOLD=0.72

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=8000
