# ═══════════════════════════════════════════════════════════════
# APEX Research Agent — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All variables are optional unless marked REQUIRED.
# ═══════════════════════════════════════════════════════════════

# ── Cloudflare Workers AI (Primary LLM + Embedding Provider) ──
# REQUIRED: API token from https://dash.cloudflare.com/profile/api-tokens
# Must have "Workers AI" permission enabled
# This single token powers ALL 9 LLM models AND embeddings
CLOUDFLARE_API_TOKEN=cfut_your_token_here

# Auto-detected from token if left empty. Set manually to skip detection.
CLOUDFLARE_ACCOUNT_ID=

# ── GitHub Models (Free Tier Fallback, 150 req/day) ──
# Optional: Personal access token from https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# ── OpenAI (Optional Fallback for Embeddings) ──
# Optional: For text-embedding-3-small embeddings as fallback
# Note: May be region-restricted. CF Workers AI is the primary provider.
OPENAI_API_KEY=

# ── Cohere (Reranking) ──
# Optional: For search result reranking
# If not set, CF Workers AI Granite-4.0-Micro is used as free reranker
COHERE_API_KEY=

# ── Web Scraping ──
# Three-tier scraper: httpx+BS4 (free) → Jina Reader → Firecrawl

# Jina Reader: Free API key from https://jina.ai/
JINA_API_KEY=

# Firecrawl: Premium scraper from https://firecrawl.dev/
# 500 free credits/month
FIRECRAWL_API_KEY=

# Note: If no scraper keys are set, the system uses:
# - Multi-source search router (29 sources, many free)
# - DuckDuckGo Lite for web search (free, no key, always works)
# - httpx + BeautifulSoup for scraping (free, no key)
# This is enough for basic functionality.

# ── Search APIs ──
# Multi-source search router queries these in parallel based on query type.
# Free sources (no key needed): OpenAlex, Crossref, DOAJ, arXiv, CORE,
#   Papers With Code, Europe PMC, ClinicalTrials.gov, Wikipedia, Wikidata,
#   GitHub, StackOverflow, Hacker News, Reddit, Mastodon, DuckDuckGo,
#   Wikipedia Offline (IPFS)

# Serper.dev: Google Search Results API — best for web queries
# Also powers: Google Scholar, Google Patents, Substack, YouTube, Reddit fallback
# Free: 2,500 queries one-time. https://serper.dev/
SERPER_API_KEY=

# Exa.ai: Neural/semantic search — best for academic/research queries
# Free: 1,000 requests/month. https://exa.ai/
EXA_API_KEY=

# Brave Search: Privacy-focused independent search index
# Free: 2,000 queries/month. https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Tavily: AI-optimized search built for agents
# Free: 1,000 requests/month. https://tavily.com/
TAVILY_API_KEY=

# NewsAPI: News aggregation from 150K+ sources
# Free: 100 requests/day. https://newsapi.org/
NEWSAPI_KEY=

# Semantic Scholar: Academic graph (200M+ papers)
# Free without key (100 req/5min), better with key (1 req/s)
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Wolfram Alpha: Computation engine (math, science, real-time data)
# Free: 2,000 queries/month. https://products.wolframalpha.com/api/
WOLFRAM_APP_ID=

# YouTube: Video search
# Free: 10,000 units/day. Falls back to Serper if no key.
# https://console.cloud.google.com/apis/api/youtube.googleapis.com
YOUTUBE_API_KEY=

# Podcast Index: Podcast search (4M+ podcasts, 100M+ episodes)
# Free API. Requires both API key and secret. Falls back to Serper.
# https://api.podcastindex.org/
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# Mastodon instance for Fediverse search
# Free, no key needed. Defaults to mastodon.social
MASTODON_INSTANCE=mastodon.social

# Contact email (used for Crossref polite pool & Unpaywall)
CONTACT_EMAIL=your-email@example.com

# ── Database ──
# PostgreSQL + pgvector. Run: docker-compose up -d db
DATABASE_URL=postgresql://apex:apex_secret@localhost:5432/apex_db

# ── Embedding Model ──
# Primary: Cloudflare Workers AI (free, uses same CF token above)
EMBEDDING_PROVIDER=cloudflare
EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768

# Available CF embedding models:
# @cf/baai/bge-small-en-v1.5  → 384 dims (fastest)
# @cf/baai/bge-base-en-v1.5   → 768 dims (recommended balance)
# @cf/baai/bge-large-en-v1.5  → 1024 dims (highest quality)

# Fallback: OpenAI (paid, may be region-restricted)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Synthesis Token Budget ──
DEFAULT_SYNTHESIS_TOKENS=150
MAX_SYNTHESIS_TOKENS=300

# ── RAG Configuration ──
RAG_TOP_K=5
RAG_FINAL_K=3
MAX_RAG_CONTEXT_TOKENS=2000
SIMILARITY_THRESHOLD=0.72

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=8000
