# APEX Research Agent — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Database ──
DATABASE_URL=postgresql://apex:apex_secret@localhost:5432/apex_db

# ── OpenAI / Embeddings ──
OPENAI_API_KEY=sk-your-openai-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── LLM Router ──
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_LLM_MODEL=gpt-4o-mini

# ── Live Scraper (Firecrawl) ──
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# ── Reranking ──
COHERE_API_KEY=co-your-key-here

# ── MCP Server ──
MCP_HOST=0.0.0.0
MCP_PORT=8081

# ── FastAPI ──
API_HOST=0.0.0.0
API_PORT=8000

# ── Token Limits ──
MAX_RAG_CONTEXT_TOKENS=2000
MAX_LIVE_SCRAPE_TOKENS=3000
MAX_SYNTHESIS_TOKENS=300
DEFAULT_SYNTHESIS_TOKENS=150

# ── Retrieval ──
RAG_TOP_K=5
RAG_FINAL_K=3
SIMILARITY_THRESHOLD=0.72
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_PCT=0.20
